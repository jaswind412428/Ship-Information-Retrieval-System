# 複製此檔案為 .env。
#
# .env 用來放「每個人本機不同、不能上傳到 GitHub」的設定，
# 例如 API Key、Token、雲端資料庫連線資訊。


# ── LangChain / 本地 Ollama 設定 ──
# 預設使用本地 Ollama 模型 qwen2.5:7b。
# 使用前請先確認 Ollama 已啟動，且已執行：
# ollama pull qwen2.5:7b
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_CHAT_MODEL=qwen2.5:7b


# ── LangChain / OpenAI 設定 ──
# 如果之後要改用 OpenAI，請把 LLM_PROVIDER 改成 openai。
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_TEMPERATURE=0
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2


# ── hsu RAG / Qdrant Cloud 設定 ──
# Qdrant URL 和 API Key 請向負責向量資料庫的組員取得。
QDRANT_URL=
QDRANT_API_KEY=


# ── CLI 輸出模式 ──
# false：簡化輸出，只顯示問題、查詢中、排序中、生成中、回覆。
# true：詳細輸出，顯示節點、docs、來源、狀態等 debug 資訊。
VERBOSE_OUTPUT=true
